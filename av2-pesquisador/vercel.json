{
  "version": 2,
  "builds": [
    {
      "src": "pesquisador_project/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(?P<path>.*)",
      "dest": "/static/$path"
    },
    {
      "src": "/(.*)",
      "dest": "pesquisador_project/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_DEBUG": "False",
    "DJANGO_SECRET_KEY": "@DJANGO_SECRET_KEY"
  }
}
